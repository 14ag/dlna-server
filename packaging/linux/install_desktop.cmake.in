set(applications_dir "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_DATADIR@/applications")
set(exec_path "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@/dlna-server-gui")

file(MAKE_DIRECTORY "${applications_dir}")
file(WRITE "${applications_dir}/dlna-server.desktop"
"[Desktop Entry]
Type=Application
Name=DLNA Server
GenericName=DLNA media server
Comment=Share local media with DLNA and UPnP clients
Exec=${exec_path}
Icon=dlna-server
Terminal=false
Categories=AudioVideo;Network;FileTransfer;
Keywords=DLNA;UPnP;media;server;streaming;
StartupWMClass=dlna-server
StartupNotify=true
")
